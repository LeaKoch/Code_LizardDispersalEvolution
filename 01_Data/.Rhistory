# Creating a dictionary
dct_anomid_ROB <- deframe(tbl_anomid_ROB)
anonymise <- function(tbl_, dct_) {
tbl_ <-
tbl_ |>
mutate(across(starts_with("ID"),
\(id_) { dct_[id_] }))
}
## For ROB
tbl_capt  <- anonymise(tbl_capt, dct_anomid_ROB)
tbl_pedigree   <- anonymise(tbl_pedigree, dct_anomid_ROB)
tbl_hapl <- anonymise(tbl_hapl, dct_anomid_ROB)
tbl_history <- anonymise(tbl_history, dct_anomid_ROB)
tbl_Propention <- anonymise(tbl_Propention, dct_anomid_ROB)
tbl_RE <- anonymise(tbl_RE, dct_anomid_ROB)
colnames(Amat) <- rownames(Amat) <-
dct_anomid_ROB[colnames(Amat)]
View(tbl_capt)
